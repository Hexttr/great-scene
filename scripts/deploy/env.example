# Copy to /opt/great-scene/web/.env on the server (chmod 600).
# Postgres (must match docker-compose.prod.yml port 5434)
POSTGRES_USER=greatscene
POSTGRES_PASSWORD=change-me
POSTGRES_DB=greatscene
DATABASE_URL=postgresql://greatscene:change-me@127.0.0.1:5434/greatscene

# App (NODE_ENV for runtime is set in systemd unit; keep build-time deps via npm ci --include=dev)
GEMINI_API_KEY=
